## SupplierService.java — Full with All Checks

```java
package com.supplier.service.service;

import com.supplier.service.dto.SupplierDTO;
import com.supplier.service.exception.DuplicateNameException;
import com.supplier.service.exception.ResourceNotFoundException;
import com.supplier.service.model.SupplierModel;
import com.supplier.service.repository.SupplierRepo;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
public class SupplierService {

    @Autowired
    private SupplierRepo supplierRepo;

    // Add Supplier
    public SupplierModel add(SupplierDTO dto) {

        // ── Duplicate name check ───────────────────────────────────────
        if (supplierRepo.existsByName(dto.getName())) {
            throw new DuplicateNameException(
                "Supplier with name '" + dto.getName() + "' already exists");
        }

        SupplierModel supplier = new SupplierModel();
        supplier.setName(dto.getName());
        supplier.setContactInfo(dto.getContactInfo());
        supplier.setMobileNumber(dto.getMobileNumber());
        supplier.setEmail(dto.getEmail());

        return supplierRepo.save(supplier);
    }

    // Update Supplier
    public SupplierModel update(Long id, SupplierDTO dto) {

        SupplierModel supplier = supplierRepo.findById(id)
            .orElseThrow(() -> new ResourceNotFoundException(
                "Supplier not found with id: " + id));

        // ── Duplicate name check on update (exclude current record) ───
        if (supplierRepo.existsByNameAndSupplierIdNot(dto.getName(), id)) {
            throw new DuplicateNameException(
                "Another supplier with name '" + dto.getName() + "' already exists");
        }

        supplier.setName(dto.getName());
        supplier.setContactInfo(dto.getContactInfo());
        supplier.setMobileNumber(dto.getMobileNumber());
        supplier.setEmail(dto.getEmail());

        return supplierRepo.save(supplier);
    }

    // Delete Supplier
    public void delete(Long id) {
        SupplierModel supplier = supplierRepo.findById(id)
            .orElseThrow(() -> new ResourceNotFoundException(
                "Supplier not found with id: " + id));

        supplierRepo.delete(supplier);
    }

    // Get All
    public List<SupplierModel> getAll() {
        return supplierRepo.findAll();
    }
}
