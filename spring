package com.order.service.service;

import com.order.service.dto.OrderDTO;
import com.order.service.exception.ResourceNotFoundException;
import com.order.service.model.OrderModel;
import com.order.service.repository.OrderRepo;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

@Service
public class OrderService {

    // ── Declare Logger ─────────────────────────────────────────────────
    private static final Logger logger =
        LoggerFactory.getLogger(OrderService.class);

    @Autowired
    private OrderRepo orderRepo;

    // Create Order
    public OrderModel createOrder(OrderDTO dto) {
        logger.info("Creating order for doctorId: {}", dto.getDoctorId());

        OrderModel order = new OrderModel();
        order.setDoctorId(dto.getDoctorId());
        order.setDrugList(dto.getDrugList());
        order.setMobileNumber(dto.getMobileNumber());
        order.setStatus("CREATED");

        OrderModel saved = orderRepo.save(order);
        logger.info("Order created successfully with id: {}", saved.getOrderId());
        return saved;
    }

    // Verify Order
    public OrderModel verify(Long id) {
        logger.info("Verifying order with id: {}", id);

        OrderModel order = orderRepo.findById(id)
            .orElseThrow(() -> {
                logger.error("Order not found with id: {}", id);
                return new ResourceNotFoundException(
                    "Order not found with id: " + id);
            });

        order.setStatus("VERIFIED");
        OrderModel saved = orderRepo.save(order);
        logger.info("Order id: {} status updated to VERIFIED", id);
        return saved;
    }

    // Pickup Order
    public OrderModel pickup(Long id) {
        logger.info("Pickup requested for order id: {}", id);

        OrderModel order = orderRepo.findById(id)
            .orElseThrow(() -> {
                logger.error("Order not found with id: {}", id);
                return new ResourceNotFoundException(
                    "Order not found with id: " + id);
            });

        if (!order.getStatus().equals("VERIFIED")) {
            logger.warn("Pickup failed for order id: {} — current status: {}",
                id, order.getStatus());
            throw new IllegalArgumentException(
                "Order must be VERIFIED before pickup. Current status: "
                + order.getStatus());
        }

        order.setStatus("PICKED UP");
        OrderModel saved = orderRepo.save(order);
        logger.info("Order id: {} status updated to PICKED UP", id);
        return saved;
    }

    // Get Order
    public OrderModel getOrder(Long id) {
        logger.debug("Fetching order with id: {}", id);

        return orderRepo.findById(id)
            .orElseThrow(() -> {
                logger.error("Order not found with id: {}", id);
                return new ResourceNotFoundException(
                    "Order not found with id: " + id);
            });
    }
}
