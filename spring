package com.user.service.service;

import com.user.service.dto.AuthResponseDTO;
import com.user.service.dto.LoginDTO;
import com.user.service.exception.ResourceNotFoundException;
import com.user.service.model.UserModel;
import com.user.service.repository.UserRepo;
import com.user.service.util.JwtUtil;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.core.authority.SimpleGrantedAuthority;
import org.springframework.security.core.userdetails.User;
import org.springframework.security.core.userdetails.UserDetails;
import org.springframework.security.core.userdetails.UserDetailsService;
import org.springframework.security.core.userdetails.UsernameNotFoundException;
import org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
public class AuthService implements UserDetailsService {
    // ↑ Implementing UserDetailsService tells Spring Security
    //   how to load your users from YOUR database

    private static final Logger logger =
        LoggerFactory.getLogger(AuthService.class);

    @Autowired
    private UserRepo userRepo;

    @Autowired
    private JwtUtil jwtUtil;

    @Autowired
    private BCryptPasswordEncoder passwordEncoder;

    // ──────────────────────────────────────────────────────────────────
    // REQUIRED by UserDetailsService
    // Spring Security calls this automatically when it needs
    // to verify who is making a request
    // ──────────────────────────────────────────────────────────────────
    @Override
    public UserDetails loadUserByUsername(String email)
            throws UsernameNotFoundException {

        logger.debug("Loading user by email: {}", email);

        UserModel user = userRepo.findByEmail(email);

        if (user == null) {
            logger.error("User not found for email: {}", email);
            throw new UsernameNotFoundException(
                "User not found with email: " + email);
        }

        // Return Spring Security's User object with
        // email, encoded password, and role as authority
        return new User(
            user.getEmail(),
            user.getPassword(),
            List.of(new SimpleGrantedAuthority("ROLE_" + user.getRole()))
        );
    }

    // ──────────────────────────────────────────────────────────────────
    // LOGIN — validates credentials and returns token + user info
    // ──────────────────────────────────────────────────────────────────
    public AuthResponseDTO login(LoginDTO dto) {
        logger.info("Login attempt for email: {}", dto.getEmail());

        // Step 1 — Find user by email
        UserModel user = userRepo.findByEmail(dto.getEmail());

        if (user == null) {
            logger.error("Login failed — user not found: {}", dto.getEmail());
            throw new ResourceNotFoundException(
                "No user found with email: " + dto.getEmail());
        }

        // Step 2 — Match raw password against encoded password in DB
        if (!passwordEncoder.matches(dto.getPassword(), user.getPassword())) {
            logger.warn("Login failed — wrong password for: {}", dto.getEmail());
            throw new IllegalArgumentException("Invalid credentials");
        }

        // Step 3 — Generate JWT token
        String token = jwtUtil.generateToken(user.getEmail(), user.getRole());

        logger.info("Login successful for: {} | role: {}",
            user.getEmail(), user.getRole());

        // Step 4 — Return clean response with token + user info
        return new AuthResponseDTO(
            token,
            user.getEmail(),
            user.getRole(),
            "Login successful"
        );
    }

    // ──────────────────────────────────────────────────────────────────
    // VALIDATE TOKEN — checks if a token is valid
    // ──────────────────────────────────────────────────────────────────
    public boolean validateToken(String token) {
        logger.debug("Validating token");

        boolean isValid = jwtUtil.validateToken(token);

        if (isValid) {
            logger.info("Token is valid");
        } else {
            logger.warn("Token is invalid or expired");
        }

        return isValid;
    }

    // ──────────────────────────────────────────────────────────────────
    // GET LOGGED IN USER — extracts user details from token
    // ──────────────────────────────────────────────────────────────────
    public UserModel getLoggedInUser(String token) {

        // Remove "Bearer " prefix if present
        if (token.startsWith("Bearer ")) {
            token = token.substring(7);
        }

        logger.debug("Extracting user from token");

        // Extract email from token
        String email = jwtUtil.getEmailFromToken(token);

        // Fetch user from DB
        UserModel user = userRepo.findByEmail(email);

        if (user == null) {
            logger.error("User not found for token email: {}", email);
            throw new ResourceNotFoundException(
                "User not found for email: " + email);
        }

        logger.info("Logged in user fetched: {}", email);
        return user;
    }
}
```

