import com.supplier.service.exception.ResourceNotFoundException;
import com.supplier.service.model.SupplierModel;
import com.supplier.service.repository.SupplierRepo;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.util.List;

@Service
public class SupplierService {

    private static final Logger logger =
        LoggerFactory.getLogger(SupplierService.class);

    @Autowired
    private SupplierRepo supplierRepo;

    // Add Supplier
    public SupplierModel add(SupplierDTO dto) {
        logger.info("Adding new supplier with name: {}", dto.getName());

        if (supplierRepo.existsByName(dto.getName())) {
            logger.warn("Duplicate supplier name attempted: {}", dto.getName());
            throw new DuplicateNameException(
                "Supplier with name '" + dto.getName() + "' already exists");
        }

        SupplierModel supplier = new SupplierModel();
        supplier.setName(dto.getName());
        supplier.setContactInfo(dto.getContactInfo());
        supplier.setMobileNumber(dto.getMobileNumber());
        supplier.setEmail(dto.getEmail());

        SupplierModel saved = supplierRepo.save(supplier);
        logger.info("Supplier added successfully with id: {}", saved.getSupplierId());
        return saved;
    }

    // Update Supplier
    public SupplierModel update(Long id, SupplierDTO dto) {
        logger.info("Updating supplier with id: {}", id);

        SupplierModel supplier = supplierRepo.findById(id)
            .orElseThrow(() -> {
                logger.error("Supplier not found with id: {}", id);
                return new ResourceNotFoundException(
                    "Supplier not found with id: " + id);
            });

        if (supplierRepo.existsByNameAndSupplierIdNot(dto.getName(), id)) {
            logger.warn("Duplicate name on update: {}", dto.getName());
            throw new DuplicateNameException(
                "Another supplier with name '" + dto.getName() + "' already exists");
        }

        supplier.setName(dto.getName());
        supplier.setContactInfo(dto.getContactInfo());
        supplier.setMobileNumber(dto.getMobileNumber());
        supplier.setEmail(dto.getEmail());

        SupplierModel saved = supplierRepo.save(supplier);
        logger.info("Supplier id: {} updated successfully", id);
        return saved;
    }

    // Delete Supplier
    public void delete(Long id) {
        logger.info("Deleting supplier with id: {}", id);

        SupplierModel supplier = supplierRepo.findById(id)
            .orElseThrow(() -> {
                logger.error("Supplier not found with id: {}", id);
                return new ResourceNotFoundException(
                    "Supplier not found with id: " + id);
            });

        supplierRepo.delete(supplier);
        logger.info("Supplier id: {} deleted successfully", id);
    }

    // Get All
    public List<SupplierModel> getAll() {
        logger.debug("Fetching all suppliers");
        List<SupplierModel> list = supplierRepo.findAll();
        logger.info("Total suppliers found: {}", list.size());
        return list;
    }
}
